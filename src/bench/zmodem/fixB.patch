+/* Flush the send_byte accumulation buffer (fallback path when send_buf unused). */
+static int send_flush(unsigned timeout)
+{
+	int result = ringbuf_write(txbuf, txbuf_len, timeout);
+	txbuf_len = 0;
+	return result;
+}
+
+/* Bulk-send callback (zm.send_buf): send a whole span, doubling any Telnet IAC
+   bytes when in Telnet mode (as send_byte does for the per-byte path). */
+int send_buf(void* unused, const uchar* buf, size_t len, unsigned timeout)
+{
+	if (telnet) {
+		size_t start = 0, i;
+		for (i = 0; i < len; i++) {
+			if (buf[i] == TELNET_IAC) {
+				if (ringbuf_write(buf + start, (i + 1) - start, timeout) != 0)
+					return -1;
+				if (ringbuf_write(buf + i, 1, timeout) != 0)   /* doubled IAC */
+					return -1;
+				start = i + 1;
+			}
+		}
+		return ringbuf_write(buf + start, len - start, timeout);
+	}
+	return ringbuf_write(buf, len, timeout);
+}
