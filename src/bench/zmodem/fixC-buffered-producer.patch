+	result = tx_write_span(txbuf, txbuf_len, timeout, &written);
+	if (written != 0 && written < txbuf_len)
+		memmove(txbuf, txbuf + written, txbuf_len - written);
+	txbuf_len -= written;
+	return result;
+}
