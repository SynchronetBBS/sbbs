# Fight event: triggers combat mock, then EndQ on win.
# Win label = NextLine (continue), Lose label = Stop (abort), no running.
# Used to verify that the Fight= hook fires and the mock outputs correctly.

Event FightEv
  Fight NextLine Stop NoRun
  EndQ

# Fight event with all three outcome labels (Win, Lose, Run).
# Allows testing Fight=L (Lose) and Fight=R (Run) branches.

Event FightCanRunEv
  Fight FightCanRunEv.Win FightCanRunEv.Lose FightCanRunEv.Run
End

Result FightCanRunEv.Win
  SetFlag G0
  EndQ

Result FightCanRunEv.Lose
  SetFlag G1
  EndQ

Result FightCanRunEv.Run
  SetFlag G2
  EndQ
