        for (index = 0; index <= table.maxBits; index += 1) {
            counts[index] = 0;
        }

        for (index = 0; index < codeLengths.length; index += 1) {
            counts[codeLengths[index] || 0] = (counts[codeLengths[index] || 0] || 0) + 1;
