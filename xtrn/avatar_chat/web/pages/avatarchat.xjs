    function ansiToCga(color) {
        if (color === 1) {
            return 4;
        }
        if (color === 4) {
            return 1;
        }
        if (color === 3) {
            return 6;
        }
        if (color === 6) {
            return 3;
        }
        return color;
    }

    function loadAnsi(data, columns, maxRows) {
        var rows = 25;
        var grid = [];
        var cx = 0;
        var cy = 0;
        var fg = 7;
        var bg = 0;
        var savedX = 0;
        var savedY = 0;
        var index = 0;

        if (!columns || columns < 1) {
            columns = 80;
        }
        if (typeof maxRows !== 'number' || maxRows < 1) {
            maxRows = 0;
        }

        function ensure(row) {
            while (grid.length < (row + 1) * columns) {
                grid.push({ code: 32, fg: 7, bg: 0 });
            }
            if (row + 1 > rows) {
                rows = row + 1;
            }
        }

        while (index < data.length) {
            var byte = data[index];

            if (byte === 0x1b && index + 1 < data.length && data[index + 1] === 0x5b) {
                var params = '';
                var cmd = '';
                var nums;
                var cursorStep = 1;
                var eraseMode = 0;
                var sgrIndex = 0;
                var value = 0;

                index += 2;
                while (index < data.length && data[index] >= 0x20 && data[index] <= 0x3f) {
                    params += String.fromCharCode(data[index]);
                    index += 1;
                }
                if (index >= data.length) {
                    break;
                }
                cmd = String.fromCharCode(data[index]);
                index += 1;
                nums = params.split(';').map(function (part) {
                    return part === '' ? undefined : parseInt(part, 10);
                });

                switch (cmd) {
                case 'A':
                    cursorStep = nums[0] || 1;
                    cy = Math.max(0, cy - cursorStep);
                    break;
                case 'B':
                    cursorStep = nums[0] || 1;
                    cy += cursorStep;
                    if (maxRows && cy >= maxRows) {
                        cy = maxRows - 1;
                    }
                    break;
                case 'C':
                    cursorStep = nums[0] || 1;
                    cx += cursorStep;
                    if (cx >= columns) {
                        cx = columns - 1;
                    }
                    break;
                case 'D':
                    cursorStep = nums[0] || 1;
                    cx = Math.max(0, cx - cursorStep);
                    break;
                case 'H':
                case 'f':
                    cy = Math.max(0, (nums[0] || 1) - 1);
                    cx = Math.max(0, (nums[1] || 1) - 1);
                    if (maxRows && cy >= maxRows) {
                        cy = maxRows - 1;
                    }
                    if (cx >= columns) {
                        cx = columns - 1;
                    }
                    break;
                case 'J':
                    eraseMode = nums[0] || 0;
                    if (eraseMode === 2) {
                        for (value = 0; value < grid.length; value += 1) {
                            grid[value] = { code: 32, fg: fg, bg: bg };
                        }
                    }
                    break;
                case 'K':
                    eraseMode = nums[0] || 0;
                    ensure(cy);
                    if (eraseMode === 0) {
                        for (value = cx; value < columns; value += 1) {
                            grid[(cy * columns) + value] = { code: 32, fg: fg, bg: bg };
                        }
                    } else if (eraseMode === 1) {
                        for (value = 0; value <= cx; value += 1) {
                            grid[(cy * columns) + value] = { code: 32, fg: fg, bg: bg };
                        }
                    } else if (eraseMode === 2) {
                        for (value = 0; value < columns; value += 1) {
                            grid[(cy * columns) + value] = { code: 32, fg: fg, bg: bg };
                        }
                    }
                    break;
                case 's':
                    savedX = cx;
                    savedY = cy;
                    break;
                case 'u':
                    cx = savedX;
                    cy = savedY;
                    break;
                case 'm':
                    if (!nums.length || (nums.length === 1 && nums[0] === undefined)) {
                        fg = 7;
                        bg = 0;
                        break;
                    }

                    for (sgrIndex = 0; sgrIndex < nums.length; sgrIndex += 1) {
                        value = nums[sgrIndex] === undefined ? 0 : nums[sgrIndex];
                        if (value === 0) {
                            fg = 7;
                            bg = 0;
                        } else if (value === 1) {
                            fg |= 8;
                        } else if (value === 5) {
                            bg |= 8;
                        } else if (value === 7) {
                            var swap = fg;
                            fg = bg;
                            bg = swap;
                        } else if (value === 22) {
                            fg &= 7;
                        } else if (value === 25) {
                            bg &= 7;
                        } else if (value >= 30 && value <= 37) {
                            fg = (fg & 8) | ansiToCga(value - 30);
                        } else if (value >= 40 && value <= 47) {
                            bg = (bg & 8) | ansiToCga(value - 40);
                        }
                    }
                    break;
                default:
