<!--AvatarChat-->

<?xjs

function loadAvatarChatWebConfig() {
    var path = js.exec_dir + '../../xtrn/avatar_chat/avatar_chat.ini';
    var file = new File(path);
    var config = {
        defaultChannel: 'main'
    };

    if (!file.open('r')) {
        return config;
    }

    config.defaultChannel = String(file.iniGetValue(null, 'default_channel', config.defaultChannel) || config.defaultChannel);
    file.close();

    return config;
}

var avatarChatWebConfig = loadAvatarChatWebConfig();
var avatarChatLoggedIn = user.number > 0;

?>
<style>
.avatar-chat-web {
    --chat-bg: #050505;
    --chat-panel: #111111;
    --chat-panel-alt: #171717;
    --chat-border: #2b2b2b;
    --chat-muted: #9e9e9e;
    --chat-fg: #efefef;
    --chat-accent: #34c6d3;
    --chat-self: #2d2ad8;
    --chat-other: #2a2a2a;
    --chat-system: #666666;
    color: var(--chat-fg);
}
.avatar-chat-web .avatar-chat-shell {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 70vh;
}
.avatar-chat-web .avatar-chat-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 1rem;
