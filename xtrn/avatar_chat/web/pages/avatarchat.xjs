                }
                continue;
            }

            if (byte === 0x0d) {
                cx = 0;
                index += 1;
                continue;
            }

            if (byte === 0x0a) {
                cy += 1;
                if (maxRows && cy >= maxRows) {
                    cy = maxRows - 1;
                }
                index += 1;
                continue;
            }

            if (byte === 0x09) {
                cx = Math.min(columns - 1, (cx + 8) & ~7);
                index += 1;
                continue;
            }

            if (!maxRows || cy < maxRows) {
                ensure(cy);
                grid[(cy * columns) + cx] = { code: byte, fg: fg, bg: bg };
                cx += 1;
                if (cx >= columns) {
                    cx = 0;
                    cy += 1;
                    if (maxRows && cy >= maxRows) {
                        cy = maxRows - 1;
                    }
                }
            }

            index += 1;
        }

        return {
            grid: grid,
            rows: rows
