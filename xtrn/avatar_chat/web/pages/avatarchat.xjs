}
.avatar-chat-web .avatar-chat-bitmap-frame {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.65rem;
    background: #000000;
    overflow: hidden;
}
.avatar-chat-web .avatar-chat-bitmap-stage {
    width: 100%;
    background: #000000;
    position: relative;
}
.avatar-chat-web .avatar-chat-bitmap-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    min-height: 7rem;
    padding: 0.9rem;
    color: var(--chat-muted);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
}
.avatar-chat-web .avatar-chat-bitmap-stage.is-error .avatar-chat-bitmap-placeholder {
    color: #ff8f8f;
}
.avatar-chat-web .avatar-chat-bitmap-image {
    display: block;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
    background: #000000;
}
.avatar-chat-web .avatar-chat-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    padding: 0.85rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0));
}
.avatar-chat-web .avatar-chat-compose-tools {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
}
.avatar-chat-web .avatar-chat-upload-button,
.avatar-chat-web .avatar-chat-upload-clear {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--chat-panel-alt);
    color: var(--chat-fg);
    border-radius: 0.85rem;
    padding: 0.65rem 0.9rem;
    line-height: 1.2;
}
.avatar-chat-web .avatar-chat-upload-clear {
    color: #f4d7d7;
}
.avatar-chat-web .avatar-chat-dropzone {
    flex: 1 1 240px;
    min-width: 0;
    border: 1px dashed rgba(52, 198, 211, 0.32);
    background: rgba(7, 20, 22, 0.72);
    color: var(--chat-muted);
    border-radius: 0.9rem;
    padding: 0.72rem 0.95rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 120ms ease, background 120ms ease, color 120ms ease, box-shadow 120ms ease;
}
.avatar-chat-web .avatar-chat-dropzone:hover,
.avatar-chat-web .avatar-chat-dropzone:focus {
    outline: none;
    color: var(--chat-fg);
    border-color: rgba(52, 198, 211, 0.6);
    background: rgba(8, 25, 28, 0.84);
}
.avatar-chat-web .avatar-chat-dropzone.is-dragover {
    color: #f4fff8;
    border-color: var(--chat-accent);
    background: rgba(12, 42, 47, 0.92);
    box-shadow: inset 0 0 0 1px rgba(52, 198, 211, 0.2);
}
.avatar-chat-web .avatar-chat-dropzone.is-busy {
    cursor: progress;
    opacity: 0.78;
}
.avatar-chat-web .avatar-chat-upload-summary {
    min-height: 1.2rem;
    font-size: 0.84rem;
    color: var(--chat-muted);
}
.avatar-chat-web .avatar-chat-upload-summary.is-ready {
    color: var(--chat-accent);
}
.avatar-chat-web .avatar-chat-upload-summary.is-error {
    color: #ff8f8f;
}
.avatar-chat-web .avatar-chat-upload-summary.is-busy {
    color: #f1c12b;
}
.avatar-chat-web .avatar-chat-compose-row {
    display: flex;
    gap: 0.5rem;
}
.avatar-chat-web .avatar-chat-input {
    flex: 1 1 auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0b0b0c;
    color: var(--chat-fg);
    border-radius: 0.9rem;
    padding: 0.8rem 0.95rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}
.avatar-chat-web .avatar-chat-send {
    border: 0;
    border-radius: 0.9rem;
    padding: 0.8rem 1rem;
    background: var(--chat-accent);
    color: #041013;
    font-weight: bold;
    min-width: 88px;
}
.avatar-chat-web .avatar-chat-login {
    color: var(--chat-muted);
    text-align: center;
    margin: 0;
    padding: 1rem 1rem 1.1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0));
}
.avatar-chat-web .avatar-chat-login a {
    color: var(--chat-accent);
}
@media (max-width: 980px) {
    .avatar-chat-web .avatar-chat-layout {
        grid-template-columns: 1fr;
        grid-template-rows: minmax(0, auto) minmax(0, 1fr);
        gap: 0.9rem;
    }
    .avatar-chat-web .avatar-chat-sidebar {
        max-height: 34vh;
    }
}
@media (max-width: 768px) {
    .avatar-chat-web {
        padding-top: 0.7rem;
    }
    .avatar-chat-web .avatar-chat-shell {
        height: calc(100vh - 128px);
        height: calc(100dvh - 128px);
        padding: 0.8rem;
    }
    .avatar-chat-web .avatar-chat-group {
        max-width: 100%;
    }
    .avatar-chat-web .avatar-chat-messages {
        min-height: 0;
        padding: 0.85rem 0.85rem 0.7rem;
    }
    .avatar-chat-web .avatar-chat-form {
        padding: 0.75rem;
    }
    .avatar-chat-web .avatar-chat-compose-row {
        flex-direction: column;
    }
    .avatar-chat-web .avatar-chat-send,
    .avatar-chat-web .avatar-chat-upload-button,
    .avatar-chat-web .avatar-chat-upload-clear {
        width: 100%;
    }
}
</style>

