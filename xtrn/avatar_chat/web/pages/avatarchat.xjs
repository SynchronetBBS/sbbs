    border-radius: 1.15rem;
    background:
        linear-gradient(180deg, rgba(6, 6, 7, 0.98), rgba(10, 10, 11, 0.99));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}
.avatar-chat-web .avatar-chat-avatar-placeholder {
