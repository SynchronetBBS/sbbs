        var counts = [];
        var nextCodes = [];
        var code = 0;
        var index = 0;

        for (index = 0; index < codeLengths.length; index += 1) {
            if ((codeLengths[index] || 0) > table.maxBits) {
                table.maxBits = codeLengths[index] || 0;
