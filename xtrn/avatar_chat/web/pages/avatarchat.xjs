        var available = state.bitCount;
        var out = 0;

        while (available < count) {
            buffer |= readByte(state) << available;
            available += 8;
        }

        out = buffer & ((1 << count) - 1);
        state.bitBuffer = buffer >>> count;
        state.bitCount = available - count;
        return out;
